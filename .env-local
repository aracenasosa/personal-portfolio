# Copy these fields into your real .env file and replace the placeholder values.
# Keep real Sanity credentials out of git.

NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=v2025-12-05

# Required only when running `pnpm migrate:i18n`.
SANITY_API_WRITE_TOKEN=your_sanity_write_token
